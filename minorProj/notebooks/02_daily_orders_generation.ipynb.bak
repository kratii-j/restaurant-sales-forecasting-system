  {
   "cell_type": "markdown",
   "id": "75c6d800",
   "metadata": {},
   "source": [
    "## 6. Validation & Sanity Checks"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 12,
   "id": "3a0549e7",
   "metadata": {
    "execution": {
     "iopub.execute_input": "2026-03-01T18:16:26.543544Z",
     "iopub.status.busy": "2026-03-01T18:16:26.543344Z",
     "iopub.status.idle": "2026-03-01T18:16:29.316113Z",
     "shell.execute_reply": "2026-03-01T18:16:29.315379Z"
    }
   },
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "🔍 Validation Checks\n",
      "==================================================\n"
     ]
    },
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "\n",
      "1️⃣  Null values:\n",
      "restaurant_id        0\n",
      "date                 0\n",
      "total_orders         0\n",
      "total_revenue        0\n",
      "avg_discount         0\n",
      "promotion_flag       0\n",
      "cancellation_rate    0\n",
      "avg_delivery_time    0\n",
      "   ✅ No nulls\n",
      "\n",
      "2️⃣  Negative orders: 0\n",
      "   ✅ All orders ≥ 0\n",
      "\n",
      "3️⃣  No zero-order days found (all restaurants have orders every day)\n"
     ]
    },
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "\n",
      "4️⃣  Weekend surge: 43.4% (target: 30–50%)\n",
      "   Weekday avg: 17.7 | Weekend avg: 25.4\n",
      "   ✅ Weekend surge present\n"
     ]
    },
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "\n",
      "5️⃣  Holiday boost: 76.1% (target: 50–100%)\n",
      "   Normal avg: 18.9 | Holiday avg: 33.3\n",
      "   ✅ Holiday boost present\n",
      "\n",
      "6️⃣  Promotion rate: 11.3% (target: ~15%)\n",
      "   ✅ Reasonable\n",
      "\n",
      "7️⃣  Restaurants covered: 9551/9551\n",
      "   ✅ All restaurants covered\n",
      "\n",
      "==================================================\n",
      "🎉 All validations passed!\n"
     ]
    }
   ],
   "source": [
    "print(\"🔍 Validation Checks\")\n",
    "print(\"=\" * 50)\n",
    "\n",
    "# Check 1: No missing values\n",
    "nulls = daily_orders.isnull().sum()\n",
    "print(f\"\\n1️⃣  Null values:\\n{nulls.to_string()}\")\n",
    "assert nulls.sum() == 0, \"❌ Found null values!\"\n",
    "print(\"   ✅ No nulls\")\n",
    "\n",
    "# Check 2: No negative orders\n",
    "neg_orders = (daily_orders[\"total_orders\"] < 0).sum()\n",
    "print(f\"\\n2️⃣  Negative orders: {neg_orders}\")\n",
    "assert neg_orders == 0, \"❌ Found negative orders!\"\n",
    "print(\"   ✅ All orders ≥ 0\")\n",
    "\n",
    "# Check 3: Revenue = 0 when orders = 0\n",
    "zero_order_mask = daily_orders[\"total_orders\"] == 0\n",
    "if zero_order_mask.any():\n",
    "    bad_rev = (daily_orders.loc[zero_order_mask, \"total_revenue\"] > 0).sum()\n",
    "    print(f\"\\n3️⃣  Revenue > 0 with 0 orders: {bad_rev}\")\n",
    "    assert bad_rev == 0, \"❌ Revenue should be 0 when orders = 0!\"\n",
    "    print(\"   ✅ Consistent\")\n",
    "else:\n",
    "    print(\"\\n3️⃣  No zero-order days found (all restaurants have orders every day)\")\n",
    "\n",
    "# Check 4: Weekend surge\n",
    "weekday_avg = daily_orders[daily_orders[\"date\"].apply(\n",
    "    lambda x: x.weekday() < 5\n",
    ")][\"total_orders\"].mean()\n",
    "weekend_avg = daily_orders[daily_orders[\"date\"].apply(\n",
    "    lambda x: x.weekday() >= 5\n",
    ")][\"total_orders\"].mean()\n",
    "surge_pct = ((weekend_avg - weekday_avg) / weekday_avg) * 100\n",
    "print(f\"\\n4️⃣  Weekend surge: {surge_pct:.1f}% (target: 30–50%)\")\n",
    "print(f\"   Weekday avg: {weekday_avg:.1f} | Weekend avg: {weekend_avg:.1f}\")\n",
    "print(\"   ✅ Weekend surge present\" if surge_pct > 25 else \"   ⚠️  Surge lower than expected\")\n",
    "\n",
    "# Check 5: Holiday boost\n",
    "holiday_dates = list(HOLIDAYS)\n",
    "holiday_avg = daily_orders[daily_orders[\"date\"].isin(holiday_dates)][\"total_orders\"].mean()\n",
    "normal_avg = daily_orders[~daily_orders[\"date\"].isin(holiday_dates)][\"total_orders\"].mean()\n",
    "holiday_pct = ((holiday_avg - normal_avg) / normal_avg) * 100\n",
    "print(f\"\\n5️⃣  Holiday boost: {holiday_pct:.1f}% (target: 50–100%)\")\n",
    "print(f\"   Normal avg: {normal_avg:.1f} | Holiday avg: {holiday_avg:.1f}\")\n",
    "print(\"   ✅ Holiday boost present\" if holiday_pct > 40 else \"   ⚠️  Boost lower than expected\")\n",
    "\n",
    "# Check 6: Promotion rate\n",
    "promo_rate = daily_orders[\"promotion_flag\"].mean() * 100\n",
    "print(f\"\\n6️⃣  Promotion rate: {promo_rate:.1f}% (target: ~15%)\")\n",
    "print(\"   ✅ Reasonable\" if 8 < promo_rate < 25 else \"   ⚠️  Outside expected range\")\n",
    "\n",
    "# Check 7: All restaurants covered\n",
    "unique_rids = daily_orders[\"restaurant_id\"].nunique()\n",
    "expected_rids = restaurants[\"Restaurant ID\"].nunique()\n",
    "print(f\"\\n7️⃣  Restaurants covered: {unique_rids}/{expected_rids}\")\n",
    "assert unique_rids == expected_rids, \"❌ Missing restaurants!\"\n",
    "print(\"   ✅ All restaurants covered\")\n",
    "\n",
    "print(\"\\n\" + \"=\" * 50)\n",
    "print(\"🎉 All validations passed!\")"
   ]
  },
  {
   "cell_type": "markdown",
