   "source": [
    "## 2. Define Simulation Parameters"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 5,
   "id": "2048a919",
   "metadata": {
    "execution": {
     "iopub.execute_input": "2026-03-01T18:15:21.380562Z",
     "iopub.status.busy": "2026-03-01T18:15:21.380414Z",
     "iopub.status.idle": "2026-03-01T18:15:21.391874Z",
     "shell.execute_reply": "2026-03-01T18:15:21.391161Z"
    }
   },
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "📅 Date range: 2025-03-01 → 2025-08-31  (184 days)\n",
      "🎉 Holidays defined: 13 days\n",
      "📆 Day-of-week multipliers set\n"
     ]
    }
   ],
   "source": [
    "# ── Date Range: 6 months of historical data ──────────────────\n",
    "END_DATE = date(2025, 8, 31)       # End of simulation window\n",
    "START_DATE = date(2025, 3, 1)      # 6 months back\n",
    "DATE_RANGE = pd.date_range(start=START_DATE, end=END_DATE, freq=\"D\")\n",
    "NUM_DAYS = len(DATE_RANGE)\n",
    "\n",
    "print(f\"📅 Date range: {START_DATE} → {END_DATE}  ({NUM_DAYS} days)\")\n",
    "\n",
    "# ── Indian Public Holidays (2025, Mar–Aug) ───────────────────\n",
    "HOLIDAYS = {\n",
    "    date(2025, 3, 14),   # Holi\n",
    "    date(2025, 3, 31),   # Eid-ul-Fitr (approx)\n",
    "    date(2025, 4, 6),    # Ram Navami\n",
    "    date(2025, 4, 10),   # Mahavir Jayanti\n",
    "    date(2025, 4, 14),   # Ambedkar Jayanti / Baisakhi\n",
    "    date(2025, 4, 18),   # Good Friday\n",
    "    date(2025, 5, 1),    # May Day\n",
    "    date(2025, 5, 12),   # Buddha Purnima\n",
    "    date(2025, 6, 7),    # Eid-ul-Adha (approx)\n",
    "    date(2025, 7, 6),    # Muharram (approx)\n",
    "    date(2025, 8, 15),   # Independence Day\n",
    "    date(2025, 8, 16),   # Janmashtami\n",
    "    date(2025, 8, 27),   # Milad-un-Nabi (approx)\n",
    "}\n",
    "\n",
    "print(f\"🎉 Holidays defined: {len(HOLIDAYS)} days\")\n",
    "\n",
    "# ── Day-of-week multipliers (Mon=0 … Sun=6) ─────────────────\n",
    "DOW_MULTIPLIERS = {\n",
    "    0: 0.85,   # Monday    – slowest\n",
    "    1: 0.90,   # Tuesday\n",
    "    2: 0.95,   # Wednesday\n",
    "    3: 1.00,   # Thursday\n",
    "    4: 1.10,   # Friday    – pick-up starts\n",
    "    5: 1.40,   # Saturday  – weekend surge\n",
    "    6: 1.35,   # Sunday    – weekend surge (slightly less than Sat)\n",
    "}\n",
    "\n",
    "print(\"📆 Day-of-week multipliers set\")"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "b5075309",
   "metadata": {},
   "source": [
    "## 3. Compute Restaurant-Specific Base Demand\n",
    "\n",
    "Each restaurant gets a **unique base order count** derived from:\n",
    "- **Votes** (proxy for popularity)\n",
    "- **Aggregate rating** (higher rating → more orders)\n",
    "- **Price range** (budget restaurants → higher volume, premium → lower volume but higher revenue)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 6,
   "id": "dd484303",
   "metadata": {
    "execution": {
     "iopub.execute_input": "2026-03-01T18:15:21.401455Z",
     "iopub.status.busy": "2026-03-01T18:15:21.400709Z",
     "iopub.status.idle": "2026-03-01T18:15:21.598582Z",
     "shell.execute_reply": "2026-03-01T18:15:21.598012Z"
    }
   },
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "✅ Base demand computed\n",
      "   Min: 5.0\n",
      "   Max: 55.1\n",
      "   Mean: 15.8\n",
      "   Median: 14.8\n"
     ]
    }
   ],
   "source": [
    "def compute_base_demand(row):\n",
    "    \"\"\"\n",
    "    Compute a restaurant-specific daily base order count.\n",
    "    \n",
    "    Logic:\n",
    "    - Start from vote-based popularity (log-scaled)\n",
    "    - Boost by rating\n",
    "    - Adjust by price range (inverse relationship with volume)\n",
    "    \"\"\"\n",
    "    # Log-scaled vote popularity → base between ~5 and ~60\n",
    "    if row[\"Votes\"] > 0:\n",
    "        vote_factor = np.log1p(row[\"Votes\"]) * 3.5\n",
    "    else:\n",
    "        vote_factor = 8.0  # default for zero-vote restaurants\n",
    "    \n",
    "    # Rating boost: 0-rated restaurants get no boost; 4.5+ get significant boost\n",
    "    rating = row[\"Aggregate rating\"]\n",
    "    if rating >= 4.0:\n",
    "        rating_factor = 1.3\n",
    "    elif rating >= 3.0:\n",
    "        rating_factor = 1.1\n",
    "    elif rating >= 2.0:\n",
    "        rating_factor = 0.9\n",
    "    elif rating > 0:\n",
    "        rating_factor = 0.7\n",
    "    else:\n",
    "        rating_factor = 0.85   # unrated\n",
    "    \n",
    "    # Price range: budget (1) → high volume; premium (4) → low volume\n",
    "    price_range = row[\"Price range\"]\n",
    "    price_volume_map = {1: 1.25, 2: 1.10, 3: 0.90, 4: 0.70}\n",
    "    price_factor = price_volume_map.get(price_range, 1.0)\n",
    "    \n",
    "    # Online delivery boost\n",
    "    delivery_boost = 1.2 if row[\"Has Online delivery\"] == \"Yes\" else 1.0\n",
    "    \n",
    "    base = vote_factor * rating_factor * price_factor * delivery_boost\n",
    "    \n",
    "    # Clamp between 5 and 120 orders/day\n",
    "    return np.clip(base, 5, 120)\n",
    "\n",
    "\n",
    "restaurants[\"base_demand\"] = restaurants.apply(compute_base_demand, axis=1)\n",
    "\n",
    "print(\"✅ Base demand computed\")\n",
    "print(f\"   Min: {restaurants['base_demand'].min():.1f}\")\n",
    "print(f\"   Max: {restaurants['base_demand'].max():.1f}\")\n",
    "print(f\"   Mean: {restaurants['base_demand'].mean():.1f}\")\n",
    "print(f\"   Median: {restaurants['base_demand'].median():.1f}\")"
   ]
  },
  {
