   "source": [
    "def seasonal_factor(d):\n",
    "    \"\"\"\n",
    "    Sine-wave seasonal trend over the year.\n",
    "    Peak around month 6-7 (summer surge for food delivery).\n",
    "    \"\"\"\n",
    "    day_of_year = d.timetuple().tm_yday\n",
    "    # Sine wave: peaks mid-year, troughs at start/end\n",
    "    return 1.0 + 0.15 * np.sin(2 * np.pi * (day_of_year - 80) / 365)\n",
    "\n",
    "\n",
    "def generate_daily_data(restaurants_df, date_range, holidays, dow_multipliers):\n",
    "    \"\"\"Generate synthetic daily orders for all restaurants.\"\"\"\n",
    "    \n",
    "    records = []\n",
    "    restaurant_ids = restaurants_df[\"Restaurant ID\"].values\n",
    "    base_demands = restaurants_df[\"base_demand\"].values\n",
    "    avg_order_vals = restaurants_df[\"avg_order_value\"].values\n",
    "    \n",
    "    total_restaurants = len(restaurant_ids)\n",
    "    \n",
    "    print(f\"🔄 Generating data for {total_restaurants} restaurants × {len(date_range)} days ...\")\n",
    "    print(f\"   Total records to generate: {total_restaurants * len(date_range):,}\")\n",
    "    \n",
    "    for idx in range(total_restaurants):\n",
    "        rid = restaurant_ids[idx]\n",
    "        base = base_demands[idx]\n",
    "        avg_val = avg_order_vals[idx]\n",
    "        \n",
    "        # Restaurant-specific noise scale (higher base → more variance)\n",
    "        noise_scale = base * 0.15\n",
    "        \n",
    "        # Restaurant-specific promotion probability (popular ones run more promos)\n",
    "        promo_prob = np.clip(0.10 + (base / 120) * 0.10, 0.08, 0.25)\n",
    "        \n",
    "        for d in date_range:\n",
    "            current_date = d.date()\n",
    "            dow = d.weekday()\n",
    "            \n",
    "            # ── 1. Seasonal factor ───────────────────────────\n",
    "            s_factor = seasonal_factor(current_date)\n",
    "            \n",
    "            # ── 2. Day-of-week multiplier ────────────────────\n",
    "            dow_factor = dow_multipliers[dow]\n",
    "            \n",
    "            # ── 3. Holiday spike (50–100% boost) ────────────\n",
    "            if current_date in holidays:\n",
    "                holiday_factor = np.random.uniform(1.50, 2.00)\n",
    "            else:\n",
    "                holiday_factor = 1.0\n",
    "            \n",
    "            # ── 4. Random noise ──────────────────────────────\n",
    "            noise = np.random.normal(0, noise_scale)\n",
    "            \n",
    "            # ── 5. Compute total orders ──────────────────────\n",
    "            orders = base * s_factor * dow_factor * holiday_factor + noise\n",
    "            orders = max(int(round(orders)), 0)\n",
    "            \n",
    "            # ── 6. Promotion & discount ──────────────────────\n",
    "            is_promo = np.random.random() < promo_prob\n",
    "            if is_promo:\n",
    "                # Discount between 5% and 30%\n",
    "                discount = round(np.random.uniform(5, 30), 1)\n",
    "                # Promotions boost orders by 10–25%\n",
    "                promo_boost = np.random.uniform(1.10, 1.25)\n",
    "                orders = int(round(orders * promo_boost))\n",
    "            else:\n",
    "                discount = round(np.random.uniform(0, 5), 1)  # minor organic discount\n",
    "            \n",
    "            # ── 7. Revenue ───────────────────────────────────\n",
    "            # Each order value varies slightly around the avg\n",
    "            per_order_variation = np.random.normal(1.0, 0.08, size=max(orders, 1))\n",
    "            per_order_variation = np.clip(per_order_variation, 0.7, 1.4)\n",
    "            \n",
    "            if orders > 0:\n",
    "                gross_revenue = sum(avg_val * v for v in per_order_variation[:orders])\n",
    "                # Apply discount\n",
    "                net_revenue = gross_revenue * (1 - discount / 100)\n",
    "            else:\n",
    "                net_revenue = 0.0\n",
    "            \n",
    "            # ── 8. Optional fields ───────────────────────────\n",
    "            # Cancellation rate: 2-8% normally, slightly higher on holidays\n",
    "            cancel_base = 0.04 if current_date not in holidays else 0.06\n",
    "            cancellation_rate = round(np.clip(\n",
    "                np.random.normal(cancel_base, 0.015), 0, 0.20\n",
    "            ), 3)\n",
    "            \n",
    "            # Avg delivery time: 25-45 min baseline\n",
    "            delivery_base = 32 + (orders / base) * 5 if base > 0 else 35\n",
    "            avg_delivery_time = round(np.clip(\n",
    "                np.random.normal(delivery_base, 4), 15, 75\n",
    "            ), 1)\n",
    "            \n",
    "            records.append({\n",
    "                \"restaurant_id\": rid,\n",
    "                \"date\": current_date,\n",
    "                \"total_orders\": orders,\n",
    "                \"total_revenue\": round(net_revenue, 2),\n",
    "                \"avg_discount\": discount,\n",
    "                \"promotion_flag\": is_promo,\n",
    "                \"cancellation_rate\": cancellation_rate,\n",
    "                \"avg_delivery_time\": avg_delivery_time,\n",
    "            })\n",
    "        \n",
    "        # Progress log every 1000 restaurants\n",
    "        if (idx + 1) % 1000 == 0:\n",
    "            print(f\"   ✓ {idx + 1}/{total_restaurants} restaurants done\")\n",
    "    \n",
    "    print(f\"   ✓ {total_restaurants}/{total_restaurants} restaurants done\")\n",
    "    return pd.DataFrame(records)\n",
    "\n",
    "\n",
    "daily_orders = generate_daily_data(restaurants, DATE_RANGE, HOLIDAYS, DOW_MULTIPLIERS)\n",
    "print(f\"\\n✅ Generated {len(daily_orders):,} records\")"
   ]
  },
