   "source": [
    "## 7. Visualize Sample Patterns"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 13,
   "id": "bb0d54f4",
   "metadata": {
    "execution": {
     "iopub.execute_input": "2026-03-01T18:16:29.318854Z",
     "iopub.status.busy": "2026-03-01T18:16:29.318654Z",
     "iopub.status.idle": "2026-03-01T18:16:49.211666Z",
     "shell.execute_reply": "2026-03-01T18:16:49.210952Z"
    }
   },
   "outputs": [
    {
     "name": "stderr",
     "output_type": "stream",
     "text": [
      "Matplotlib is building the font cache; this may take a moment.\n"
     ]
    },
    {
     "data": {
      "image/png": "",
      "text/plain": [
       "<Figure size 1600x1000 with 4 Axes>"
      ]
     },
     "metadata": {},
     "output_type": "display_data"
    },
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "✅ Sample plot saved to data/processed/sample_orders_plot.png\n"
     ]
    }
   ],
   "source": [
    "import matplotlib.pyplot as plt\n",
    "import matplotlib.dates as mdates\n",
    "\n",
    "# Pick 4 restaurants with varying popularity\n",
    "sample_ids = restaurants.nlargest(2, \"Votes\")[\"Restaurant ID\"].tolist() + \\\n",
    "             restaurants.nsmallest(2, \"Votes\")[\"Restaurant ID\"].tolist()\n",
    "sample_names = restaurants.set_index(\"Restaurant ID\").loc[sample_ids, \"Restaurant Name\"].values\n",
    "\n",
    "fig, axes = plt.subplots(2, 2, figsize=(16, 10), sharex=True)\n",
    "fig.suptitle(\"Daily Orders – Sample Restaurants (6 Months)\", fontsize=16, fontweight=\"bold\")\n",
    "\n",
    "for ax, rid, name in zip(axes.flat, sample_ids, sample_names):\n",
    "    subset = daily_orders[daily_orders[\"restaurant_id\"] == rid].copy()\n",
    "    subset = subset.sort_values(\"date\")\n",
    "    \n",
    "    # Plot orders\n",
    "    ax.plot(subset[\"date\"], subset[\"total_orders\"], linewidth=0.8, alpha=0.7, label=\"Daily Orders\")\n",
    "    \n",
    "    # 7-day rolling average\n",
    "    rolling = subset[\"total_orders\"].rolling(7).mean()\n",
    "    ax.plot(subset[\"date\"], rolling, linewidth=2, color=\"red\", label=\"7-day MA\")\n",
    "    \n",
    "    # Mark holidays\n",
    "    for h in HOLIDAYS:\n",
    "        if START_DATE <= h <= END_DATE:\n",
    "            ax.axvline(x=h, color=\"green\", alpha=0.3, linestyle=\"--\")\n",
    "    \n",
    "    # Mark promotions\n",
    "    promo_days = subset[subset[\"promotion_flag\"] == True]\n",
    "    ax.scatter(promo_days[\"date\"], promo_days[\"total_orders\"],\n",
    "               color=\"orange\", s=10, alpha=0.5, zorder=5, label=\"Promo Day\")\n",
    "    \n",
    "    ax.set_title(f\"{name[:30]}... (ID: {rid})\" if len(name) > 30 else f\"{name} (ID: {rid})\",\n",
    "                 fontsize=11)\n",
    "    ax.set_ylabel(\"Orders\")\n",
    "    ax.legend(fontsize=8, loc=\"upper left\")\n",
    "    ax.xaxis.set_major_formatter(mdates.DateFormatter(\"%b\"))\n",
    "    ax.grid(True, alpha=0.3)\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.savefig(os.path.join(DATA_DIR, \"..\", \"processed\", \"sample_orders_plot.png\"), dpi=150, bbox_inches=\"tight\")\n",
    "plt.show()\n",
    "print(\"✅ Sample plot saved to data/processed/sample_orders_plot.png\")"
   ]
  },
