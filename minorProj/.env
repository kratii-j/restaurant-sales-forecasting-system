# ============================================================
# Environment Variables – Restaurant Sales Forecasting System
# ============================================================
# ⚠️  Never commit this file to version control.
#     Make sure .env is listed in your .gitignore.
# ============================================================

# ── App Settings ─────────────────────────────────────────────
APP_ENV=development
DEBUG=True
SECRET_KEY=your-secret-key-here

# ── API Keys ─────────────────────────────────────────────────
# OpenWeather API (for weather feature enrichment)
OPENWEATHER_API_KEY=your-openweather-api-key-here

# Google Maps API (for location / footfall data)
GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=sqlite:///data/restaurant_sales.db

# ── FastAPI / Uvicorn ────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
